{
  "name": "outreach-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "esbuild src/index.ts src/orchestrator/index.ts --bundle --platform=node --outdir=dist --format=cjs --packages=external --outbase=src",
    "start": "node dist/index.js",
    "start:orchestrator": "node dist/orchestrator/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:orchestrator": "tsx watch src/orchestrator/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@bull-board/api": "^6.5.0",
    "@bull-board/express": "^6.5.0",
    "bullmq": "^5.34.0",
    "@supabase/supabase-js": "^2.100.0",
    "express": "^4.21.0",
    "ioredis": "^5.4.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.5.5",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.3",
    "vitest": "^2.0.0"
  }
}
